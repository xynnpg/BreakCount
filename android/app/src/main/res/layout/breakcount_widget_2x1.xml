<?xml version="1.0" encoding="utf-8"?>
<!-- 2x1 — small horizontal pill (~110×56dp)
     Premium Apple/Samsung UI style: white rounded card, no divider lines.
     [large "12" days] | ["days to\nSPRING BREAK" label] | [progress ring] -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="14dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Large days number — hero element, left-anchored -->
    <TextView
        android:id="@+id/tv_days"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:textColor="#FF6F4E37"
        android:includeFontPadding="false"
        android:layout_marginEnd="12dp" />

    <!-- Break label — "days to\nSPRING BREAK" — fills middle space -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="start"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tv_vibe_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="14sp"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/tv_break_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SPRING BREAK"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FF6F4E37"
            android:maxLines="2"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="1.1" />

    </LinearLayout>

    <!-- Progress ring — clean, decorative, no text -->
    <RelativeLayout
        android:layout_width="40dp"
        android:layout_height="40dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/widget_ring_track"
            android:scaleType="fitXY"
            android:contentDescription="@null" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/widget_ring"
            android:scaleType="fitXY"
            android:contentDescription="@null" />

        <!-- Year percentage — small, centered inside ring -->
        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="--%"
            android:textSize="9sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:textColor="#FF6F4E37"
            android:includeFontPadding="false" />

    </RelativeLayout>

</LinearLayout>

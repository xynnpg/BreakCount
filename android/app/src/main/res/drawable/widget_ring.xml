<?xml version="1.0" encoding="utf-8"?>
<!-- Simple oval ring used as progress circle in widgets.
     Safe for Samsung RemoteViews: single <shape>, no layer-list, no gradient. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <stroke
        android:width="5dp"
        android:color="#FF6F4E37" />
    <solid android:color="#00000000" />
</shape>
